# ═══════════════════════════════════════════════════════════════════
# TELEGRAM BOT - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════

# Telegram Bot Configuration
# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Bot Mode: webhook (production) or polling (development)
BOT_MODE=webhook

# Webhook Configuration (required for webhook mode)
# Set to your Render URL once deployed
WEBHOOK_URL=https://your-bot.onrender.com

# Keep webhooks secure with a secret token
WEBHOOK_SECRET=your-random-secret-token-here

# API Configuration
API_BASE_URL=http://localhost:4000
API_PORT=4000

# Payment Provider: paystack or flutterwave
PAYMENT_PROVIDER=paystack

# State & Persistence
REDIS_URL=redis://localhost:6379
STATE_STORE_KEY=telegram-shop-bot:state:v1

# Server Configuration
PORT=3000
NODE_ENV=production

# Keep-Alive (prevents Render free tier from sleeping)
ENABLE_KEEP_ALIVE=true

# Timeout Configuration (in milliseconds)
BOT_STARTUP_TIMEOUT_MS=15000
